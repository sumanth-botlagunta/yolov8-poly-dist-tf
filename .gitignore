# Checkpoints and model outputs
initial_checkpoint_folder/
checkpoints/
*.ckpt
*.ckpt.index
*.ckpt.data-*
*.weights.h5
saved_model/
*.tflite
*.pb

# TensorBoard
tb_events/
runs/

# Experiment outputs
outputs/
results/
*.json
# ...but keep committed config/tooling JSON that lives in tracked folders.
# (settings.local.json stays ignored via the rule near the top of this file.)
!.claude/settings.json
!serving/**/*.json

