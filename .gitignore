# ── Project-specific excludes ────────────────────────────────────────────────
tmp_reference_docs/

# .claude/ is committed (shared skills, settings, agents) for easy team setup.
# Only the per-user local override file stays out of version control.
.claude/settings.local.json

# Checkpoints and model outputs
initial_checkpoint_folder/
checkpoints/
*.ckpt
*.ckpt.index
*.ckpt.data-*
*.weights.h5
saved_model/
*.tflite
*.pb

# TensorBoard
tb_events/
runs/

# Experiment outputs
outputs/
results/
*.json
# ...but keep committed config/tooling JSON that lives in tracked folders.
# (settings.local.json stays ignored via the rule near the top of this file.)
!.claude/settings.json
!serving/**/*.json

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
MANIFEST

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env
*.env

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── TensorFlow / ML ───────────────────────────────────────────────────────────
tfds_cache/
tensorflow_datasets/
wandb/
mlruns/
.claude/projects/
